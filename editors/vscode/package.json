{
  "name": "openspec-lsp-vscode",
  "displayName": "OpenSpec LSP",
  "description": "OpenSpec Markdown diagnostics, completions, hover, symbols, links, and code actions.",
  "version": "0.1.0",
  "publisher": "tmc",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:openspec.validateProject",
    "onCommand:openspec.insertRequirement",
    "onCommand:openspec.openExtensionModel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "OpenSpec",
      "properties": {
        "openspec.lsp.path": {
          "type": "string",
          "default": "openspec-lsp",
          "description": "Path to the openspec-lsp binary."
        },
        "openspec.lsp.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace communication with openspec-lsp."
        }
      }
    },
    "commands": [
      {
        "command": "openspec.validateProject",
        "title": "OpenSpec: Validate Project"
      },
      {
        "command": "openspec.insertRequirement",
        "title": "OpenSpec: Insert Requirement"
      },
      {
        "command": "openspec.openExtensionModel",
        "title": "OpenSpec: Open Extension Model"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "check": "tsc -p ./ --noEmit"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  }
}
